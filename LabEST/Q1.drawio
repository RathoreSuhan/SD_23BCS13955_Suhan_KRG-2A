        <mxCell id="fr-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;labelBackgroundColor=none;" value="&lt;font style=&quot;font-size: 30px;&quot;&gt;FUNCTIONAL REQUIREMENTS&lt;/font&gt;" vertex="1">
