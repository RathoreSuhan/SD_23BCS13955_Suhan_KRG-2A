        <mxCell id="fr-body" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;labelBackgroundColor=none;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;1. USER REGISTRATION WITH OTP EMAIL VERIFICATION&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;2. SECURE LOGIN WITH JWT AUTHENTICATION&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;3. REAL-TIME 1-1 AND GROUP MESSAGING VIA SOCKET.IO&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;4. FRIEND REQUESTS, BLOCK/UNBLOCK USERS&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;5. TYPING INDICATORS, ONLINE/OFFLINE PRESENCE&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;6. MESSAGE REPLY, EDIT, DELETE (ME / EVERYONE)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;7. GROUP CREATION, ADMIN CONTROLS, MEMBER MANAGEMENT&lt;/font&gt;&lt;/div&gt;" vertex="1">
